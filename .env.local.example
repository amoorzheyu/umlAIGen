# Qwen API Configuration (OpenAI-compatible)
QWEN_API_BASE_URL=http://localhost:8000/v1
QWEN_MODEL=Qwen/Qwen3.5-9B
QWEN_API_KEY=none

# PlantUML image base URLs (server-side only)
# 提示：请把空字符串替换为你的 PlantUML 服务地址（不需要末尾 `/`）
PLANTUML_PNG_BASE_URL=https://localhost:8001/plantuml/png
PLANTUML_SVG_BASE_URL=https://localhost:8001/plantuml/svg
